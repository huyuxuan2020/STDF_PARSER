{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "STDF Parser",
  "version": "0.1.1",
  "identifier": "com.stdfparser.viewer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "STDF Parser",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/huyuxuan2020/STDF_PARSER/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYzNDRGQzVCQ0RBMzM2RjIKUldUeU5xUE5XL3hFWXdmZWNIeXRZZUFLSTdwNjdCdy85dnhzZjdaYmxsV0ZCN2xMSjI1ekVxNVcK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
